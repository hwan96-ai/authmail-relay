# Copy this file to `.env` and fill in real values. Do NOT commit `.env`.

# ===== Required =====

# SMTP server hostname (e.g. smtp.gmail.com)
SMTP_HOST=
# SMTP login account
SMTP_USER=
# SMTP password / app password (Gmail: use an app password, not your account password)
SMTP_PASSWORD=

# Shared bearer token that clients pass as `Authorization: Bearer <API_KEY>`.
# Generate a strong random value, e.g.:
#   openssl rand -hex 32
# Leave no spaces around `=`. Do not wrap in quotes.
API_KEY=replace-with-long-random-secret

# ===== Optional =====

# SMTP port (default: 587)
#SMTP_PORT=587
# Sender address shown in the From header (default: same as SMTP_USER)
#SMTP_FROM=
# STARTTLS toggle (default: true; set to `false` only for local dev against a no-TLS relay)
#SMTP_USE_TLS=true

# Enables /send/magic-link. If unset, that endpoint returns 503.
#MAGIC_LINK_BASE_URL=https://myapp.com

# ===== uvicorn bind =====

# Bind host.
#   - Local `python -m email_service`: default is 127.0.0.1 (loopback only).
#   - Docker: use 0.0.0.0 so the port published on the host is actually reachable.
# docker-compose.yml already sets this to 0.0.0.0; override here only if needed.
#HOST=0.0.0.0
# Bind port inside the container (default: 8000). The host-side port is mapped in docker-compose.yml.
#PORT=8000
